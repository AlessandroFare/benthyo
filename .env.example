# Benthyo environment variables
# Copy to .env (gitignored) and fill in real values for local development.
# NEVER commit the .env file.

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<your-anon-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/benthyo

# ─── NestJS API ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
API_CORS_ORIGIN=http://localhost:5173,http://localhost:7357,http://127.0.0.1:7357
CORS_ORIGIN=

# ─── Auth (admin key for moderation routes) ──────────────────────────────────
ADMIN_API_KEY=<random-32-byte-hex>

# ─── Redis (BullMQ job queue) ─────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Cloudflare R2 (photo storage) ────────────────────────────────────────────
R2_ACCOUNT_ID=<your-r2-account-id>
R2_ACCESS_KEY_ID=<your-r2-access-key>
R2_SECRET_ACCESS_KEY=<your-r2-secret-key>
R2_BUCKET=benthyo-photos
R2_PUBLIC_URL=https://pub-<your-bucket>.r2.dev

# ─── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=<your-resend-api-key>
DIGEST_FROM_EMAIL=Benthyo <digest@benthyo.com>

# ─── Stripe (billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>

# ─── Edge Functions ───────────────────────────────────────────────────────────
# Shared secret used by pg_cron and trusted admin clients when invoking
# darwin-core-export and weekly-digest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SHARED_SECRET=<your-32-byte-hex>

# ─── ETL pipelines ───────────────────────────────────────────────────────────
ETL_SYSTEM_USER_ID=<uuid-of-system-user>
GBIF_MAX_RECORDS=5000
OBIS_MAX_RECORDS=3000
WORMS_MAX_PER_TERM=200
LOG_LEVEL=info

# FishBase / SeaLifeBase enrichment (static Parquet snapshots on source.coop; no API key).
FISHBASE_DATA_BASE=https://data.source.coop/cboettig/fishbase
FISHBASE_FB_VERSION=v24.07
FISHBASE_SLB_VERSION=v24.07
FISHBASE_SERVERS=fishbase,sealifebase
FISHBASE_MAX=100000
FISHBASE_BATCH_SIZE=1000

# ─── Dive site ETL ────────────────────────────────────────────────────────────
OPENDIVEMAP_MAX_SITES=5000
OPENDIVEMAP_API_URL=https://api.opendivemap.com/v1
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
OVERPASS_REGIONS=
# Wikidata SPARQL dive-site source (public endpoint; no API key). A descriptive
# User-Agent is required by the Wikidata Query Service usage policy.
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql
WIKIDATA_USER_AGENT=BenthyoETL/1.0 (https://benthyo.com; dive-site enrichment)
WIKIDATA_CATEGORY_LIMIT=5000
DIVENUMBER_API_KEY=<register-at-divenumber>
DIVENUMBER_API_URL=https://divenumber.com/api/v1/sites
APIFY_TOKEN=<register-at-apify>
APIFY_GOOGLE_MAPS_ACTOR=compass~crawler-google-places
# Multi-region: runs regions sequentially, each with a 150km customGeolocation circle.
# Known regions: europe, asia, americas, africa, oceania. Pipe-separated to run multiple.
APIFY_SEARCH_REGION=europe|asia|americas|africa|oceania
APIFY_MAX_PLACES_PER_SEARCH=20
# Hard cost cap per region ($0.90 × 5 regions = $4.50, within $5 budget)
# Protects against the actor's known "city expansion" bug (maxCrawledPlaces ignored).
APIFY_MAX_COST_PER_REGION_USD=0.9
# Legacy: uses locationQuery text (city/region) — less precise than customGeolocation
APIFY_SEARCH_LOCATION=Nice, France
TAVILY_API_KEY=<register-at-tavily>
INAT_IMAGE_BATCH_SIZE=50
INAT_IMAGE_MAX_SPECIES=500

# ─── AI models (zero-budget) ──────────────────────────────────────────────────
# OpenCode Zen — free LLM used by the ETL (dive-site-discovery enumeration,
# species name normalisation). Register at https://opencode.ai/zen
OPENCODE_ZEN_API_KEY=<register-at-opencode-zen>
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_ZEN_MODEL=deepseek-v4-flash-free
# Groq — free multimodal (vision) model used by the API for photo species
# identification (POST /species/identify/ai). Register at https://console.groq.com
# When absent, identification falls back to iNaturalist vision only.
GROQ_API_KEY=<register-at-groq>
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ─── Sentry (error monitoring) ─────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.01
SENTRY_PROFILES_SAMPLE_RATE=0.01
SENTRY_ENABLE_PROFILING=false

# ─── Dashboard (Vite, must be prefixed VITE_) ────────────────────────────────
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=<your-anon-publishable-key>
VITE_API_URL=http://localhost:3000/api/v1
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=

# ─── Flutter mobile (--dart-define) ──────────────────────────────────────────
# API_URL=http://10.0.2.2:3000/api/v1
# AUTH_REDIRECT_URL=io.benthyo.com://login-callback
PMTILES_TILE_URL=https://media.benthyo.com/tiles/{z}/{x}/{y}.png

# ─── Master key for medical-form encryption (DD-5.6) ─────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production: the API fail-fasts at boot if unset (>=16 chars).
# The key + salt are threaded into the medical RPCs (migration 043); when
# unset, encryption falls back to a PUBLIC dev placeholder — never ship that.
MEDICAL_ENCRYPTION_MASTER_KEY=<your-32-byte-hex>
# Secret server-side salt mixed into the HMAC key derivation (migration 038).
MEDICAL_ENCRYPTION_KEY_SALT=<your-32-byte-hex>
