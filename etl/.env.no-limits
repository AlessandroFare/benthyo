# ═══════════════════════════════════════════════════════════════════
# Benthyo ETL — Environment Variables (no-limits free-tier config)
# ═══════════════════════════════════════════════════════════════════
# Copy to .env and fill in your keys. All values below are set to
# maximize data within free-tier limits of each service.
# Every variable name below is verified against the actual code.
#
# ── Required ───────────────────────────────────────────────────────

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ETL system user (run scripts/seed-etl-system-user.sql first, then use the printed id)
ETL_SYSTEM_USER_ID=00000000-0000-0000-0000-0000000e7100

# ── LLM (text completion — Google Gemini preferred, zero rate limits) ──
# Google Gemini 2.5 Flash: 1500 req/day, no per-minute limit, supports vision
# Get a key at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your-google-ai-key
GOOGLE_LLM_MODEL=gemini-2.5-flash

# ── LLM fallback 1 (Groq — faster but rate limited) ─────────────────
# Groq free tier: 30 req/min, 100K TPD
# Get a key at https://console.groq.com
GROQ_API_KEY=your-groq-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Text model for discovery + enrichment (llama-3.3-70b is more capable and
# has higher TPM limit than 8b; use llama-3.1-8b-instant only if speed is critical):
GROQ_LLM_MODEL=llama-3.3-70b-versatile
# Vision model for dive-map reading (multimodal):
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Provider selection: 'google' (default, fastest, no rate limits) or 'groq' or 'opencode-zen'
ETL_LLM_PROVIDER=google

# ── LLM fallback (OpenCode Zen — slower but capable) ───────────────
# Used when ETL_LLM_PROVIDER=opencode-zen or when Groq key is missing
# Get a key at https://opencode.ai/zen
OPENCODE_ZEN_API_KEY=your-zen-key
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_ZEN_MODEL=deepseek-v4-flash-free

# ── Apify (free tier: $5/month credits) ────────────────────────────
APIFY_TOKEN=your-apify-token
APIFY_GOOGLE_MAPS_ACTOR=compass~crawler-google-places
# Max places per search string per region
APIFY_MAX_PLACES_PER_SEARCH=30
# Cost cap per region in USD (keep under $1 to stay in free tier)
APIFY_MAX_COST_PER_REGION_USD=0.9
# Run timeout in milliseconds
APIFY_RUN_TIMEOUT_MS=600000
# Regions to crawl: europe|asia|americas|africa|oceania
APIFY_SEARCH_REGION=europe|asia|americas|africa|oceania

# ── Tavily (free tier: 1000 searches/month) ───────────────────────
TAVILY_API_KEY=your-tavily-key
TAVILY_API_URL=https://api.tavily.com/search

# ── Species ETL: no limits ─────────────────────────────────────────

# GBIF: no API key needed (free, rate-limited by IP ~5-10 req/s)
GBIF_MAX_RECORDS_PER_REGION=5000
# Regions (default: all 11). Comma-separated to limit:
# GBIF_REGIONS=caribbean,red_sea,southeast_asia

# OBIS: no API key needed (free, ~3 req/s)
OBIS_MAX_RECORDS=50000

# SEAMAP: no API key needed (uses OBIS API)
SEAMAP_MAX_RECORDS=10000

# iNaturalist: no API key needed (free, 100 req/min without key)
INAT_API_BASE=https://api.inaturalist.org/v1
INAT_OBS_MAX_RECORDS=5000
# iNaturalist taxon lookup (backfill common names + inat_taxon_id)
INAT_TAXON_MAX_SPECIES=5000
INAT_TAXON_BATCH_SIZE=100
INAT_TAXON_MIN_SCORE=90
# iNaturalist image backfill
INAT_IMAGE_MAX_SPECIES=2000
INAT_IMAGE_BATCH_SIZE=50

# WoRMS: no API key needed (free, ~5 req/s)
WORMS_MAX=5000
WORMS_BATCH_SIZE=500

# Wikimedia Commons: no API key needed (free, 200 req/s with proper UA)
WIKIMEDIA_MAX_SPECIES=2000
WIKIMEDIA_BATCH_SIZE=100
WIKIMEDIA_USER_AGENT=Benthyo/1.0 (https://benthyo.com; contact@benthyo.com)

# Tavily species images (limited by Tavily free tier: 1000 searches/month)
TAVILY_SPECIES_MAX=500

# FishBase/SeaLifeBase: no API key needed (static parquet from source.coop)
FISHBASE_MAX=100000
FISHBASE_BATCH_SIZE=1000

# ── Dive site ETL: no limits ───────────────────────────────────────

# OpenDiveMap: no API key needed (free)
OPENDIVEMAP_API_URL=https://api.opendivemap.com/v1
OPENDIVEMAP_MAX_SITES=50000
OPENDIVEMAP_PAGE_SIZE=500

# Overpass: no API key needed (free, but rate-limited ~2 req/min)
# Alternative mirrors: https://overpass.kumi.systems/api/interpreter
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
# Regions (default: all 9). Comma-separated to limit:
# OVERPASS_REGIONS=mediterranean,caribbean,red_sea

# DiveNumber: requires API key (free registration at divenumber.com)
DIVENUMBER_API_KEY=your-divenumber-key
DIVENUMBER_API_URL=https://divenumber.com/api/v1/sites

# Wikidata SPARQL: no API key needed (free)
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql
WIKIDATA_CATEGORY_LIMIT=5000
WIKIDATA_USER_AGENT=Benthyo/1.0 (https://benthyo.com; contact@benthyo.com)

# Wikivoyage: no API key needed (free)
WIKIVOYAGE_API_URL=https://en.wikivoyage.org/w/api.php
WIKIVOYAGE_MAX_PAGES=200

# Nominatim geocoder: no API key needed (free, 1 req/s strict policy)
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_USER_AGENT=Benthyo/1.0 (https://benthyo.com; contact@benthyo.com)

# ── Dive site discovery (LLM-based) ────────────────────────────────
# Max destinations per region (LLM enumeration)
DISCOVERY_MAX_DESTINATIONS=100
# Max sites per destination to ask the LLM for
DISCOVERY_MAX_SITES_PER_DEST=40
# Max Commons photos to geosearch per region
DISCOVERY_COMMONS_PHOTOS=100
# Regions (default: all 11)
# DISCOVERY_REGIONS=caribbean,red_sea,southeast_asia

# ── Dive map vision (image search + vision LLM) ────────────────────
# Destinations per run (each costs ~10 image searches + ~10 vision calls)
# Groq free tier: 30 req/min for vision, so 30 dests × 10 images = 300 calls ≈ 10 min
DIVE_MAP_MAX_DESTINATIONS=30
# Images per destination
DIVE_MAP_IMAGES_PER_DEST=10
# Min cross-map votes to keep a site (1 = trust single maps)
DIVE_MAP_MIN_VOTES=1
# LLM-enumerated destinations per region
DIVE_MAP_DESTS_PER_REGION=30
# Regions (default: all 11)
# DIVE_MAP_REGIONS=caribbean,red_sea,southeast_asia

# ── Log level ──────────────────────────────────────────────────────
LOG_LEVEL=info
