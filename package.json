{
  "name": "benthyo",
  "private": true,
  "version": "0.1.0",
  "description": "Benthyo monorepo root",
  "scripts": {
    "build": "pnpm --filter @benthyo/types build && pnpm --filter @benthyo/ui build",
    "dev:api": "pnpm --filter @benthyo/api start:dev",
    "dev:dashboard": "pnpm --filter @benthyo/dashboard dev",
    "test:etl": "pnpm --filter @benthyo/etl test",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "vitest": "^3.0.5",
      "vite": "^6.4.3",
      "webpack": "^5.104.1",
      "multer": "^2.2.0",
      "lodash": "^4.18.1",
      "glob": "^11.0.1",
      "picomatch": "^4.0.2",
      "qs": "^6.15.2",
      "js-yaml": "^4.2.0",
      "tmp": "^0.2.4",
      "dompurify": "^3.4.11",
      "esbuild": "^0.25.0",
      "file-type": "^21.3.2",
      "ajv": "^8.18.0",
      "@opentelemetry/core": "^2.8.0"
    }
  }
}
